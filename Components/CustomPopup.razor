
<DxPopup @bind-Visible="PopupVisible" ShowCloseButton="false" ShowFooter="true" HeaderText = "@HeaderText"   Width="400px" >
    <BodyContentTemplate>
      @ChildContent
    </BodyContentTemplate>
       <FooterContentTemplate>
         <CustomButton Text="Cancel" OnClick = "@ClosePopup" RenderStyle="ButtonRenderStyle.None" StyleMode = "ButtonRenderStyleMode.Contained" ButtonSizeMode="SizeMode.Medium"/>
         <CustomButton OnClick="OnSubmit" Text="@(IsEditMode ? "Update": "Add")" RenderStyle="ButtonRenderStyle.Dark" StyleMode = "ButtonRenderStyleMode.Contained" ButtonSizeMode="SizeMode.Medium"/>
    </FooterContentTemplate>
</DxPopup>


@code {
    
     [Parameter] public bool PopupVisible { get; set; }
     
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public EventCallback<bool> PopupVisibleChanged { get; set; }
      
    [Parameter] public string HeaderText { get; set; } = string.Empty; 
    
    
      
    [Parameter] public RenderFragment? ChildContent { get; set; }
    
    [Parameter] public EventCallback OnSubmit { get; set; }
        
      private async Task ClosePopup()
    {
        await PopupVisibleChanged.InvokeAsync(false);
    }

}